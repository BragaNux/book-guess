@page "/ranking"
@inject BookGuessApiClient Api

<PageTitle>Ranking — BookGuess</PageTitle>

<div class="container page-enter" style="padding-top:40px;padding-bottom:72px;max-width:760px">
    <div class="ranking-header">
        <div>
            <div class="flex items-center gap-10">
                <Icon Name="trophy" Size="22" Class="text-warning" />
                <h2>Ranking</h2>
            </div>
            <p class="mt-6">Os melhores leitores da plataforma</p>
        </div>
        <div class="ranking-tabs">
            @foreach (var tab in _tabs)
            {
                <button class="ranking-tab @(_activeTab == tab.Key ? "ranking-tab--active" : "")"
                        @onclick="() => LoadRanking(tab.Key)">
                    <Icon Name="@tab.Icon" Size="13" />
                    @tab.Label
                </button>
            }
        </div>
    </div>

    @if (_loading)
    {
        <div style="display:flex;flex-direction:column;gap:3px">
            @for (int i = 0; i < 8; i++) { <div class="skeleton" style="height:62px;border-radius:8px"></div> }
        </div>
    }
    else if (_entries is not null && _entries.Any())
    {
        var all  = _entries.ToList();
        var top  = all.Take(3).ToList();
        var rest = all.Skip(3).ToList();

        @if (top.Count >= 3)
        {
            <div class="podium stagger">
                <div class="podium-card podium-card--2">
                    <div class="podium-medal">🥈</div>
                    <div class="avatar avatar-md">@top[1].Name[0]</div>
                    <div class="podium-name">@top[1].Name</div>
                    <div class="podium-score">@top[1].Score pts</div>
                </div>
                <div class="podium-card podium-card--1">
                    <div class="podium-crown">
                        <Icon Name="trophy" Size="18" Class="text-warning" />
                    </div>
                    <div class="podium-medal">🥇</div>
                    <div class="avatar avatar-lg">@top[0].Name[0]</div>
                    <div class="podium-name">@top[0].Name</div>
                    <div class="podium-score">@top[0].Score pts</div>
                </div>
                <div class="podium-card podium-card--3">
                    <div class="podium-medal">🥉</div>
                    <div class="avatar avatar-md">@top[2].Name[0]</div>
                    <div class="podium-name">@top[2].Name</div>
                    <div class="podium-score">@top[2].Score pts</div>
                </div>
            </div>
        }
        else
        {
            <!-- < 3 entradas: lista simples com destaque visual -->
            <div class="card-surface" style="padding:0;overflow:hidden">
                @foreach (var e in top)
                {
                    <RankingRow Entry="e" />
                }
            </div>
        }

        @if (rest.Count > 0)
        {
            <div class="card-surface" style="padding:0;overflow:hidden;margin-top:20px">
                @foreach (var e in rest)
                {
                    <RankingRow Entry="e" />
                }
            </div>
        }
    }
    else if (_entries is not null)
    {
        <div class="empty-state">
            <div class="empty-state__icon">
                <Icon Name="trophy" Size="32" />
            </div>
            <h3 class="mt-16">Nenhum resultado ainda</h3>
            <p class="mt-8">Seja o primeiro a jogar e apareça aqui!</p>
            <a href="/" class="btn btn-primary mt-24">
                <Icon Name="play" Size="14" />
                Jogar Agora
            </a>
        </div>
    }
</div>

<style>
    .ranking-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        margin-bottom: 32px;
        gap: 16px;
    }
    .gap-10 { gap: 10px; }
    .mt-6   { margin-top: 6px; }

    .ranking-tabs {
        display: flex;
        gap: 3px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius-sm);
        padding: 4px;
        flex-shrink: 0;
    }
    .ranking-tab {
        display: flex;
        align-items: center;
        gap: 5px;
        padding: 7px 14px;
        border-radius: 6px;
        font-size: 0.78rem;
        font-weight: 600;
        cursor: pointer;
        border: none;
        background: transparent;
        color: var(--text-muted);
        transition: all var(--transition);
        font-family: inherit;
    }
    .ranking-tab:hover { color: var(--text); }
    .ranking-tab--active { background: var(--primary); color: #fff; box-shadow: 0 2px 8px rgba(109,93,252,0.35); }

    /* Podium */
    .podium {
        display: grid;
        grid-template-columns: 1fr 1fr 1fr;
        gap: 12px;
        align-items: flex-end;
        margin-bottom: 4px;
    }
    .podium-card {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        padding: 20px 16px;
        text-align: center;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 8px;
        transition: all var(--transition-md);
    }
    .podium-card:hover { transform: translateY(-2px); }
    .podium-card--1 {
        border-color: rgba(255,215,0,0.35);
        background: linear-gradient(180deg, rgba(255,215,0,0.04) 0%, var(--card) 100%);
        padding-top: 24px;
    }
    .podium-card--2 { border-color: rgba(180,190,200,0.25); }
    .podium-card--3 { border-color: rgba(205,136,73,0.25); }
    .podium-crown {
        display: flex;
        justify-content: center;
        margin-bottom: -4px;
        filter: drop-shadow(0 0 8px rgba(245,158,11,0.5));
    }
    .podium-medal  { font-size: 1.6rem; line-height: 1; }
    .podium-name   { font-size: 0.84rem; font-weight: 600; margin-top: 4px; }
    .podium-score  { font-size: 0.75rem; color: var(--text-muted); }

    .empty-state {
        text-align: center;
        padding: 72px 32px;
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius-lg);
    }
    .empty-state__icon {
        width: 64px; height: 64px;
        border-radius: 50%;
        background: rgba(124,133,160,0.1);
        border: 1px solid var(--border);
        color: var(--text-muted);
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0 auto;
    }

    @@media (max-width: 560px) {
        .ranking-header { flex-direction: column; }
        .podium { grid-template-columns: 1fr; }
    }
</style>

@code {
    private IEnumerable<RankingEntry>? _entries;
    private bool _loading;
    private string _activeTab = "global";

    private readonly (string Key, string Label, string Icon)[] _tabs =
    [
        ("global",  "Geral",   "globe"),
        ("weekly",  "Semanal", "clock"),
        ("monthly", "Mensal",  "calendar"),
    ];

    protected override async Task OnInitializedAsync() => await LoadRanking("global");

    private async Task LoadRanking(string tab)
    {
        _activeTab = tab;
        _loading   = true;
        StateHasChanged();
        var res = await Api.GetRankingAsync(tab);
        if (res?.Success == true) _entries = res.Data;
        _loading = false;
    }
}
