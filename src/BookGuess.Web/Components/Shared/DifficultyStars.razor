<div class="difficulty-stars">
    @for (int i = 1; i <= 5; i++)
    {
        bool filled = i <= Level;
        <Icon Name="star"
              Size="14"
              Fill="@(filled ? "currentColor" : "none")"
              StrokeWidth="@(filled ? "0" : "1.5")"
              Class="@(filled ? "star-icon-filled" : "star-icon-empty")" />
    }
</div>

@code {
    [Parameter] public int Level { get; set; }
}
