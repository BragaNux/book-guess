@using BookGuess.Web.Models

<div class="container page-enter" style="padding-top:48px;padding-bottom:72px;max-width:580px">
    <div class="result-wrapper">

        <!-- Icon animado -->
        <div class="result-icon-wrap">
            @if (IsWin)
            {
                <div class="result-icon-ring result-icon-ring--win animate-bounce-in">
                    <Icon Name="check-circle-2" Size="40" Class="text-success" />
                </div>
            }
            else
            {
                <div class="result-icon-ring result-icon-ring--lose animate-bounce-in">
                    <Icon Name="x-circle" Size="40" Class="text-danger" />
                </div>
            }
        </div>

        <h2 class="result-heading">@(IsWin ? "Parabéns!" : "Tentativas esgotadas!")</h2>
        <p class="result-sub">@(IsWin ? "Você identificou o livro corretamente!" : "Não se preocupe — tente novamente amanhã no desafio diário.")</p>

        @if (Result is not null)
        {
            <div class="result-book-reveal">
                <div class="result-book-label">
                    <Icon Name="book-open" Size="12" />
                    O livro era
                </div>
                <div class="result-book-title">@Result.BookTitle</div>
                <div class="result-book-author">por @Result.Author</div>
            </div>

            <div class="result-score-row">
                <div class="result-block">
                    <div class="result-num text-gradient">@Result.Score</div>
                    <div class="result-block-label">
                        <Icon Name="bar-chart-2" Size="13" />
                        pontos
                    </div>
                </div>
                @if (IsWin)
                {
                    <div class="result-divider"></div>
                    <div class="result-block">
                        <div class="result-num result-num--xp">+@Result.XPEarned</div>
                        <div class="result-block-label">
                            <Icon Name="zap" Size="13" />
                            XP ganho
                        </div>
                    </div>
                }
            </div>

            @if (!string.IsNullOrEmpty(Result.Trivia))
            {
                <div class="result-trivia">
                    <div class="result-trivia__label">
                        <Icon Name="lightbulb" Size="13" />
                        Sabia que...
                    </div>
                    <p>@Result.Trivia</p>
                </div>
            }
        }

        <div class="result-actions">
            <button class="btn btn-primary btn-lg w-full" @onclick="OnPlayAgain">
                <Icon Name="refresh-cw" Size="16" />
                @(IsWin ? "Jogar Novamente" : "Nova Partida")
            </button>
            @if (!IsWin)
            {
                <a href="/?daily=true" class="btn btn-secondary w-full">
                    <Icon Name="calendar" Size="14" />
                    Desafio Diário de Amanhã
                </a>
            }
            <a href="/ranking" class="btn btn-secondary w-full">
                <Icon Name="trophy" Size="14" />
                Ver Ranking
            </a>
        </div>
    </div>
</div>

<style>
    .result-wrapper {
        background: var(--card);
        border: 1px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 44px 36px;
        text-align: center;
        box-shadow: 0 24px 64px rgba(0,0,0,0.4);
    }
    .result-icon-wrap { margin-bottom: 20px; display: flex; justify-content: center; }
    .result-icon-ring {
        width: 80px; height: 80px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .result-icon-ring--win  {
        background: rgba(34,197,94,0.1);
        border: 2px solid rgba(34,197,94,0.3);
        box-shadow: 0 0 30px rgba(34,197,94,0.25);
    }
    .result-icon-ring--lose {
        background: rgba(239,68,68,0.1);
        border: 2px solid rgba(239,68,68,0.3);
        box-shadow: 0 0 30px rgba(239,68,68,0.2);
    }
    .result-heading { font-size: 1.7rem; font-weight: 800; letter-spacing: -0.02em; }
    .result-sub     { color: var(--text-muted); margin-top: 6px; font-size: 0.9rem; }

    .result-book-reveal {
        margin: 28px 0;
        padding: 22px;
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        position: relative;
        overflow: hidden;
    }
    .result-book-reveal::before {
        content: '';
        position: absolute;
        top: 0; left: 0; right: 0;
        height: 2px;
        background: linear-gradient(90deg, var(--primary), var(--secondary));
    }
    .result-book-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 5px;
        font-size: 0.68rem;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-muted);
        font-weight: 600;
        margin-bottom: 10px;
    }
    .result-book-title  { font-size: 1.4rem; font-weight: 800; letter-spacing: -0.02em; margin-top: 4px; }
    .result-book-author { color: var(--text-muted); margin-top: 4px; font-size: 0.9rem; }

    .result-score-row {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 32px;
        margin: 24px 0;
    }
    .result-block { text-align: center; }
    .result-num {
        font-size: 2.8rem;
        font-weight: 900;
        line-height: 1;
        letter-spacing: -0.04em;
    }
    .result-num--xp { color: var(--warning); }
    .result-block-label {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 4px;
        font-size: 0.72rem;
        color: var(--text-muted);
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-top: 6px;
    }
    .result-divider { width: 1px; height: 48px; background: var(--border); }

    .result-trivia {
        text-align: left;
        padding: 16px 18px;
        background: var(--surface);
        border-left: 3px solid var(--primary);
        border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
        margin-bottom: 24px;
    }
    .result-trivia__label {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.7rem;
        font-weight: 700;
        color: var(--primary);
        text-transform: uppercase;
        letter-spacing: 0.06em;
        margin-bottom: 8px;
    }
    .result-trivia p { font-style: italic; font-size: 0.875rem; line-height: 1.65; }

    .result-actions { display: flex; flex-direction: column; gap: 8px; }
</style>

@code {
    [Parameter] public MatchResultResponse? Result    { get; set; }
    [Parameter] public bool                IsWin     { get; set; }
    [Parameter] public EventCallback       OnPlayAgain { get; set; }
}
